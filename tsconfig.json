{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./plugin",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/**/*"]
}
